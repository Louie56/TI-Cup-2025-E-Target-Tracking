GPIO8.associatedPins[2].interruptPriority = "1";
GPIO8.associatedPins[2].polarity          = "RISE_FALL";
GPIO8.associatedPins[3].$name             = "A2side";
GPIO8.associatedPins[3].direction         = "INPUT";
GPIO8.associatedPins[3].assignedPort      = "PORTA";
GPIO8.associatedPins[3].assignedPin       = "24";
