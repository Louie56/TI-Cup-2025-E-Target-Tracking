GPIO4.$name                         = "GPIO_GRP_2";
GPIO4.port                          = "PORTB";
GPIO4.associatedPins[0].$name       = "PIN_3";
GPIO4.associatedPins[0].assignedPin = "6";

GPIO5.$name                         = "MOTOR_A";
GPIO5.port                          = "PORTB";
GPIO5.associatedPins.create(2);
GPIO5.associatedPins[0].$name       = "AIN1";
GPIO5.associatedPins[0].assignedPin = "20";
GPIO5.associatedPins[1].$name       = "AIN2";
